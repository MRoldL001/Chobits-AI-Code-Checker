{
  "name": "code-checker",
  "displayName": "代码检查器",
  "description": "智能代码质量检查工具，AI驱动评分，多彩状态栏显示",
  "version": "1.0.0",
  "publisher": "MRoldL001",
  "repository": {
    "type": "git",
    "url": "https://github.com/MRoldL001/AI-Code-Checker.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:python",
    "onLanguage:html",
    "onLanguage:css"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeChecker.checkCodeQuality",
        "title": "代码检查器：检查代码质量"
      }
    ],
    "configuration": {
      "title": "代码检查器",
      "properties": {
        "codeChecker.aiProvider": {
          "type": "string",
          "enum": [
            "local",
            "remote"
          ],
          "default": "local",
          "description": "选择AI服务提供商（local=本地Ollama, remote=远程API）"
        },
        "codeChecker.local.model": {
          "type": "string",
          "default": "llama2",
          "description": "本地Ollama模型名称"
        },
        "codeChecker.remote.endpoint": {
          "type": "string",
          "default": "",
          "description": "远程API地址（支持OpenAI兼容格式）"
        },
        "codeChecker.remote.apiKey": {
          "type": "string",
          "default": "",
          "description": "远程API密钥（可选）"
        },
        "codeChecker.remote.model": {
          "type": "string",
          "default": "",
          "description": "远程API模型名称"
        },
        "codeChecker.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "启用代码质量分数自动更新"
        },
        "codeChecker.updateDebounceMs": {
          "type": "number",
          "default": 2000,
          "description": "自动更新的防抖时间（毫秒）"
        },
        "codeChecker.statusBarPosition": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "right",
          "description": "状态栏项位置"
        },
        "codeChecker.systemPrompt": {
          "type": "string",
          "default": "You are a code quality evaluator. Score the code 0-100:\n- 90-100: Excellent, production-ready code\n- 80-89: Good quality, minor issues\n- 70-79: Acceptable, some problems\n- 60-69: Just acceptable, needs improvement\n- 0-59: Poor, serious issues\nIf the code runs without errors and is functional, give at least 60 points.\nIMPORTANT: Return a number like 73, 81, 67, 88, 62, 77, etc. Avoid always returning multiples of 5. Return ONLY the number.",
          "description": "AI代码质量检查的系统提示词"
        }
      }
    },
    "keybindings": [
      {
        "command": "codeChecker.checkCodeQuality",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.9"
  },
  "dependencies": {
    "axios": "^1.6.7"
  }
}
